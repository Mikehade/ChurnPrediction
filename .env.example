# Database backend: "sqlite" (default) or "postgres"
DATABASE_BACKEND=sqlite

# Only used when DATABASE_BACKEND=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bank_churn_db

# Used by the Streamlit API-client app
CHURN_API_URL=http://localhost:8000/api/v1

# Comma-separated list, e.g. http://localhost:8501,http://127.0.0.1:8501
# CORS_ORIGINS=http://localhost:8501
